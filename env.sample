############################################
# Noorlytics – Configuration (.env)
############################################

# -------------------------------------------------
# REQUIRED
# -------------------------------------------------

# Your Noorlytics license key
# (provided after purchase or trial activation)
NOOR_LICENSE_KEY=


# -------------------------------------------------
# AI BACKEND
# -------------------------------------------------

# Choose which AI backend to use:
# - ollama  (recommended, runs locally)
# - openai  (requires OpenAI API key)
NOOR_MODE=ollama


# -------------------------------------------------
# OPENAI (optional)
# -------------------------------------------------

# Required only if NOOR_MODE=openai
OPENAI_API_KEY=


# -------------------------------------------------
# LOCAL AI (Ollama)
# -------------------------------------------------

# Ollama model to use.
# Make sure the model is installed locally:
#   ollama pull mistral
NOOR_MODEL=mistral:latest

# Context window size (tokens)
# Higher values allow larger files but use more memory
NOOR_NUM_CTX=4096


# -------------------------------------------------
# PRIVACY & COMPLIANCE
# -------------------------------------------------

# When enabled, Noorlytics avoids sending sensitive code
# or metadata outside the local machine.
# Recommended to keep enabled.
COMPLIANCE_MODE=true


# -------------------------------------------------
# NETWORK & PERFORMANCE
# -------------------------------------------------

# HTTP timeout in seconds.
# Increase this if you use remote models or slow machines.
NOOR_HTTP_TIMEOUT=120

# How long the model should stay loaded in memory
# Examples: 30s, 5m, 30m
NOOR_KEEP_ALIVE=30m


# -------------------------------------------------
# AI GENERATION SETTINGS
# (advanced – defaults are safe)
# -------------------------------------------------

# Temperature controls randomness.
# 0.0 = deterministic, higher = more creative
NOOR_TEMP_ANALYZE=0.0
NOOR_TEMP_REFACTOR=0.0

# Maximum tokens generated per request
NOOR_ANALYZE_NUM_PREDICT=512
NOOR_REFACTOR_NUM_PREDICT=1024


# -------------------------------------------------
# FILE CHUNKING
# -------------------------------------------------

# Maximum number of lines per chunk sent to the AI
NOOR_MAX_CHUNK_LINES=120

# Overlap between chunks (lines)
NOOR_CHUNK_OVERLAP=20


# -------------------------------------------------
# OUTPUT & FILE HANDLING
# -------------------------------------------------

# Directory where reports will be written
NOOR_REPORTS_DIR=reports

# Maximum file size (bytes) that Noorlytics will analyze
NOOR_MAX_FILE_BYTES=100000

# File extensions to include (comma-separated)
NOOR_ALLOWED_EXT=.py,.js,.ts,.java